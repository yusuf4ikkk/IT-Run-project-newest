msgstr "Git + командада иштөө"

msgid "Мини-проект: лендинг"
msgstr "Мини-долбоор: лендинг"

msgid "БОНУС"
msgstr "БОНУС"

msgid "Шаблоны резюме и чек-лист собеседований"
msgstr "Резюме шаблондору жана интервью чек-листи"

msgid "отзывы"
msgstr "пионерлердин пикирлери"

msgid "Говорят выпускники"
msgstr "Бүтүрүүчүлөр айтышат"

msgid "Коротко и по делу — что понравилось и что получили."
msgstr "Кыска жана так — эмне жакты жана эмне алдыңыз."